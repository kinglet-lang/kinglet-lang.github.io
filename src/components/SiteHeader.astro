---
// Header for the marketing home shell (uses home.css classes).
---
<header class="site-header">
  <div class="shell header-row">
    <a class="wordmark" href="/" aria-label="Kinglet home">
      <img src="/kinglet-brand.svg" alt="Kinglet" width="130" height="40" />
    </a>
    <nav class="primary-nav" aria-label="Primary navigation">
      <a href="/docs">Docs</a>
      <a href="/news">News</a>
      <a href="https://github.com/kinglet-lang/bootstrap/discussions">Community</a>
      <span class="nav-soon" aria-disabled="true" title="Coming soon">Playground<b>soon</b></span>
      <a href="https://github.com/kinglet-lang" class="github-link" aria-label="Kinglet on GitHub" title="GitHub">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path fill="currentColor" d="M12 .7a11.5 11.5 0 0 0-3.64 22.41c.58.11.79-.25.79-.56v-2.23c-3.22.7-3.9-1.37-3.9-1.37-.53-1.34-1.29-1.7-1.29-1.7-1.05-.72.08-.71.08-.71 1.17.08 1.78 1.2 1.78 1.2 1.04 1.78 2.72 1.27 3.38.97.1-.75.41-1.27.74-1.56-2.57-.29-5.27-1.29-5.27-5.68 0-1.25.45-2.28 1.19-3.08-.12-.29-.52-1.46.11-3.04 0 0 .97-.31 3.16 1.18A10.98 10.98 0 0 1 12 6.14c.98 0 1.95.13 2.87.39 2.2-1.49 3.16-1.18 3.16-1.18.63 1.58.23 2.75.11 3.04.74.8 1.19 1.83 1.19 3.08 0 4.4-2.71 5.38-5.29 5.67.42.36.79 1.06.79 2.15v3.26c0 .31.21.68.8.56A11.5 11.5 0 0 0 12 .7Z" />
        </svg>
      </a>
    </nav>
    <details class="mobile-nav">
      <summary aria-label="Open navigation menu">
        <span>Menu</span>
        <i aria-hidden="true"><b></b><b></b></i>
      </summary>
      <nav aria-label="Mobile navigation">
        <a href="/docs"><span>Docs</span></a>
        <a href="/news"><span>News</span></a>
        <a href="https://github.com/kinglet-lang/bootstrap/discussions"><span>Community</span><b aria-hidden="true">↗</b></a>
        <span class="mobile-soon"><span>Playground</span><b>Soon</b></span>
        <a href="https://github.com/kinglet-lang"><span>GitHub</span><b aria-hidden="true">↗</b></a>
      </nav>
    </details>
  </div>
</header>
