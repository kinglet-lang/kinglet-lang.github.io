---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
---
<BaseLayout title="Kinglet Programming Language">
<SiteHeader />

<main>
  <section class="hero">
    <div class="shell hero-grid">
      <p class="eyebrow hero-stagger" style="--stagger:0">The Kinglet programming language</p>

      <h1 class="hero-stagger" style="--stagger:1">A native language with <em>explicit boundaries.</em></h1>

      <div class="hero-actions hero-stagger" style="--stagger:2">
        <button class="button" type="button" disabled aria-disabled="true">Download</button>
        <a class="text-link" href="/docs">Read the guide →</a>
      </div>

      <div class="hero-editor hero-stagger" style="--stagger:3" aria-label="Kinglet source example">
        <div class="hero-editor__head">
          <span>shape.kl</span>
          <div class="hero-editor__actions">
            <button type="button" class="hero-editor__btn" data-run="hero" data-target="hero-output">Run</button>
            <button type="button" class="hero-editor__btn" id="hero-copy" aria-label="Copy code"><span id="hero-copy-label">Copy</span></button>
          </div>
        </div>
<pre id="hero-code" data-stdout="3.14"><code><span class="kw">using</span> io;

<span class="kw">enum</span> <span class="ty">Shape</span> {'{'}
  <span class="ty">Circle</span>(<span class="ty">float</span>),
  <span class="ty">Rect</span>(<span class="ty">float</span>, <span class="ty">float</span>),
{'}'}

<span class="ty">float</span> <span class="fn">area</span>(<span class="ty">Shape</span> s) {'{'}
  <span class="kw">return</span> s <span class="kw">match</span> {'{'}
    <span class="ty">Shape</span>::<span class="ty">Circle</span>(<span class="kw">let</span> r) ={'>'} <span class="num">3.14</span> * r * r,
    <span class="ty">Shape</span>::<span class="ty">Rect</span>(<span class="kw">let</span> w, <span class="kw">let</span> h) ={'>'} w * h,
  {'}'};
{'}'}

<span class="ty">int</span> <span class="fn">main</span>() {'{'}
  <span class="ty">Shape</span> c = <span class="ty">Shape</span>::<span class="ty">Circle</span>(<span class="num">1.0</span>);
  io::out.<span class="fn">line</span>(<span class="fn">area</span>(c));
  <span class="kw">return</span> <span class="num">0</span>;
{'}'}<span class="caret" aria-hidden="true"></span></code></pre>
        <div class="hero-editor__output" id="hero-output" hidden aria-live="polite">
          <div class="hero-editor__output-head">
            <span>$ kinglet shape.kl</span>
            <span class="hero-editor__preview-tag">preview</span>
          </div>
<pre class="hero-editor__stdout"></pre>
        </div>
      </div>
    </div>
  </section>

  <section class="language" id="language">
    <div class="shell section-grid">
      <header class="section-intro">
        <p class="section-number">Language</p>
        <h2>A small surface for systems that need to stay understandable.</h2>
        <p>Kinglet compiles directly to native code and stays close to C-family syntax, while making the parts a reader usually has to guess — lifetimes, states, effects — visible in the source.</p>
      </header>
      <div class="feature-list">
        <article>
          <div><h3>Ownership</h3></div>
          <div><p>Resource lifetimes are part of the program model rather than hidden behind a tracing runtime.</p></div>
        </article>
        <article>
          <div><h3>Algebraic data types</h3></div>
          <div><p>Enums carry data; matches are exhaustive, so every state is accounted for at the point it is used.</p></div>
        </article>
        <article>
          <div><h3>Explicit capabilities</h3></div>
          <div><p>Modules such as <code>io</code>, encoding, and filesystem are imported by name and used at visible call sites.</p></div>
        </article>
        <article>
          <div><h3>Native by default</h3></div>
          <div><p>The compiler emits object code through LLVM and produces ordinary platform binaries — no VM, no bundled runtime.</p></div>
        </article>
      </div>
    </div>
  </section>

  <section class="code-section" aria-labelledby="code-title">
    <div class="shell code-grid">
      <div class="code-copy">
        <p class="section-number">In code</p>
        <h2 id="code-title">Failure is a value.</h2>
        <p>Nullable types, propagation with <code>?</code>, and <code>try / catch</code> make error paths visible instead of implicit.</p>
        <a href="/docs">Explore the syntax →</a>
      </div>
      <div class="editor" aria-label="Kinglet code example">
        <div class="editor-head">
          <span>read.kl</span>
          <div class="hero-editor__actions">
            <button type="button" class="hero-editor__btn" data-run="code" data-target="code-output">Run</button>
            <button type="button" class="hero-editor__btn" id="code-copy" aria-label="Copy code"><span id="code-copy-label">Copy</span></button>
          </div>
        </div>
<pre id="code-block" data-stdout="a = 420&#10;n = -99"><code><span class="kw">using</span> io;

<span class="ty">int</span>? <span class="fn">parse</span>(<span class="ty">string</span> s) {'{'}
  <span class="kw">return</span> <span class="ty">int</span>(s)? * <span class="num">10</span>;
{'}'}

<span class="ty">int</span> <span class="fn">main</span>() {'{'}
  <span class="ty">int</span>? a = <span class="fn">parse</span>(<span class="num">"42"</span>) ?: <span class="num">-1</span>;
  io::out.<span class="fn">line</span>(<span class="num">"a = {'{}'}"</span>, a);

  <span class="ty">int</span> n;
  <span class="kw">try</span> {'{'}
    n = <span class="ty">int</span>(<span class="num">"bad"</span>)?;
  {'}'} <span class="kw">catch</span> (<span class="kw">let</span> ex: <span class="ty">CastError</span>) {'{'}
    n = <span class="num">-99</span>;
  {'}'}
  io::out.<span class="fn">line</span>(<span class="num">"n = {'{}'}"</span>, n);
  <span class="kw">return</span> <span class="num">0</span>;
{'}'}</code></pre>
        <div class="hero-editor__output" id="code-output" hidden aria-live="polite">
          <div class="hero-editor__output-head">
            <span>$ kinglet read.kl</span>
            <span class="hero-editor__preview-tag">preview</span>
          </div>
<pre class="hero-editor__stdout"></pre>
        </div>
      </div>
    </div>
  </section>

  <section class="compiler" id="compiler">
    <div class="shell section-grid">
      <header class="section-intro">
        <p class="section-number">Toolchain</p>
        <h2>One compiler, from source to a native executable.</h2>
        <p>The bootstrap compiler covers parsing, semantic checking, Kinglet IR, LLVM lowering, a small runtime, and the command-line driver — all in one binary.</p>
      </header>
      <div class="pipeline" aria-label="Compilation pipeline">
        <div><strong>01 · Source</strong><span>.kl</span></div>
        <div><strong>02 · Check</strong><span>Types &amp; semantics</span></div>
        <div><strong>03 · Lower</strong><span>Kinglet IR</span></div>
        <div><strong>04 · Emit</strong><span>Native binary</span></div>
      </div>
      <div class="project-links">
        <a href="https://github.com/kinglet-lang/bootstrap"><span>Compiler source</span><small>github.com/kinglet-lang/bootstrap</small></a>
        <a href="https://github.com/kinglet-lang/bootstrap/releases"><span>Releases</span><small>Prebuilt toolchains and release notes</small></a>
        <a href="https://github.com/kinglet-lang/ADRs"><span>Design decisions</span><small>Architecture decision records</small></a>
      </div>
    </div>
  </section>

  <section class="get-started" id="get-started">
    <div class="shell start-grid">
      <div>
        <p class="section-number">Get started</p>
        <h2>Install the toolchain and build your first program.</h2>
        <p>The installer works on macOS and Linux. Windows is supported through PowerShell.</p>
      </div>
      <div class="install-block">
        <div class="install-command"><span id="prompt">$</span><code id="cmd">curl -fsSL https://kinglet-lang.org/install.sh | sh</code><button id="copy" type="button"><span id="copy-label">Copy</span></button></div>
        <p class="install-note">Windows PowerShell: <code>irm https://kinglet-lang.org/install.ps1 | iex</code></p>
        <div class="start-links">
          <a href="/docs">Read the guide →</a>
          <a href="https://github.com/kinglet-lang/bootstrap">Build from source →</a>
        </div>
      </div>
    </div>
  </section>
</main>

<SiteFooter />

<script is:inline>
(function () {
  var cmdEl = document.getElementById('cmd');
  var copyBtn = document.getElementById('copy');
  var copyLabel = document.getElementById('copy-label');
  copyBtn.addEventListener('click', function () {
    if (navigator.clipboard) navigator.clipboard.writeText(cmdEl.textContent);
    copyLabel.textContent = 'Copied';
    window.setTimeout(function () { copyLabel.textContent = 'Copy'; }, 1400);
  });

  var codeEl = document.getElementById('hero-code');
  var heroCopyBtn = document.getElementById('hero-copy');
  var heroCopyLabel = document.getElementById('hero-copy-label');
  if (codeEl && heroCopyBtn) {
    heroCopyBtn.addEventListener('click', function () {
      if (navigator.clipboard) navigator.clipboard.writeText(codeEl.textContent.trim());
      heroCopyLabel.textContent = 'Copied';
      window.setTimeout(function () { heroCopyLabel.textContent = 'Copy'; }, 1400);
    });
  }

  var codeBlock = document.getElementById('code-block');
  var codeCopyBtn = document.getElementById('code-copy');
  var codeCopyLabel = document.getElementById('code-copy-label');
  if (codeBlock && codeCopyBtn) {
    codeCopyBtn.addEventListener('click', function () {
      if (navigator.clipboard) navigator.clipboard.writeText(codeBlock.textContent.trim());
      codeCopyLabel.textContent = 'Copied';
      window.setTimeout(function () { codeCopyLabel.textContent = 'Copy'; }, 1400);
    });
  }

  // Run buttons: reveal the preview output panel for each example.
  var sources = { hero: codeEl, code: codeBlock };
  document.querySelectorAll('[data-run]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var source = sources[btn.dataset.run];
      var panel = document.getElementById(btn.dataset.target);
      if (!source || !panel) return;
      var stdout = source.getAttribute('data-stdout') || '';
      var out = panel.querySelector('.hero-editor__stdout');
      if (panel.hidden) {
        out.textContent = stdout;
        panel.hidden = false;
        btn.textContent = 'Hide';
      } else {
        panel.hidden = true;
        btn.textContent = 'Run';
      }
    });
  });
})();
</script>
</BaseLayout>
