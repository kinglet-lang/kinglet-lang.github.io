---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('news', ({ data }) => !data.draft);
  return posts.map(post => ({ params: { slug: post.id }, props: { post } }));
}
const { post } = Astro.props;
const { Content } = await render(post);
const fmt = (d: Date) => d.toLocaleDateString('en', { year: 'numeric', month: 'long', day: '2-digit', timeZone: 'UTC' });
---
<BaseLayout title={`${post.data.title} — Kinglet News`} description={post.data.description}>
<SiteHeader />
<main class="news-page">
  <article class="news-article">
    <header>
      <div class="shell news-article__head">
        <div><a class="back-link" href="/news">← Project log</a><time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time></div>
        <div><div class="news-tags">{post.data.tags.map(tag => <span>{tag}</span>)}</div><h1>{post.data.title}</h1>{post.data.description && <p>{post.data.description}</p>}</div>
      </div>
    </header>
    <div class="shell news-article__body"><div class="prose"><Content /></div></div>
  </article>
</main>
<SiteFooter />
</BaseLayout>
