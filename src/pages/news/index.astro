---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('news', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const fmt = (d: Date) => d.toISOString().slice(0, 10);
---
<BaseLayout title="News — Kinglet" description="Release notes, tutorials, and other news from the Kinglet project.">
<SiteHeader />

<main>
  <section class="hero">
    <div class="shell hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">News</p>
        <h1>What's shipping<br />in the Kinglet project.</h1>
        <p class="lede">Release notes, tutorial drops, and design updates. Written in the open.</p>
      </div>
    </div>
  </section>

  <section class="language">
    <div class="shell">
      <ul class="post-list">
        {posts.map(post => (
          <li>
            <a href={`/news/${post.id}/`}>
              <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
              <h2>{post.data.title}</h2>
              {post.data.description && <p>{post.data.description}</p>}
            </a>
          </li>
        ))}
        {posts.length === 0 && <li><p>No posts yet.</p></li>}
      </ul>
    </div>
  </section>
</main>

<SiteFooter />
</BaseLayout>
