---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const fmt = (d: Date) => d.toLocaleDateString('en', { year: 'numeric', month: 'long', day: '2-digit', timeZone: 'UTC' });
---
<BaseLayout title="Blog — Kinglet" description="Long-form engineering and language-design writing from the Kinglet project.">
<SiteHeader />
<main class="blog-page">
  <header class="blog-masthead shell">
    <p class="eyebrow">Long-form notes</p>
    <h1>Thinking through<br />the language.</h1>
    <p>Essays about Kinglet's design constraints, implementation choices, and the trade-offs behind them.</p>
  </header>
  <section class="shell essay-list">
    {posts.map(post => (
      <article><a href={`/blog/${post.id}/`}><div><time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>{post.data.author && <span>{post.data.author}</span>}</div><h2>{post.data.title}</h2>{post.data.description && <p>{post.data.description}</p>}<b>Read essay →</b></a></article>
    ))}
    {posts.length === 0 && <div class="empty-state"><strong>No essays published yet.</strong><p>Long-form design writing will appear here when it is ready.</p></div>}
  </section>
</main>
<SiteFooter />
</BaseLayout>
