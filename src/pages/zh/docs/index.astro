---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import SiteFooter from '../../../components/SiteFooter.astro';
import { getCollection } from 'astro:content';
import { t } from '../../../i18n';

const locale = 'zh';
const entries = (await getCollection('docs', ({ data }) => !data.draft && (data.locale ?? 'en') === locale))
  .sort((a, b) => a.data.order - b.data.order);
const bySection: Record<string, typeof entries> = {};
for (const entry of entries) {
  const key = entry.data.section ?? 'guide';
  (bySection[key] ??= []).push(entry);
}
const sections = Object.entries(bySection);
const idOf = (fullId: string) => fullId.replace(/^zh\//, '');
---
<BaseLayout title={`${t('nav.docs', locale)} — ${t('site.title', locale)}`} description={t('docs.hero.lead', locale)}>
<SiteHeader />
<main class="docs-page">
  <header class="subpage-hero docs-hero">
    <div class="shell subpage-hero__grid">
      <div>
        <p class="eyebrow">{t('docs.hero.eyebrow', locale)}</p>
        <h1>{t('docs.hero.title.a', locale)}<br />{t('docs.hero.title.b', locale)}</h1>
      </div>
      <p>{t('docs.hero.lead', locale)}</p>
    </div>
  </header>

  <div class="shell docs-index-layout">
    <aside class="docs-index-nav" aria-label="Documentation sections">
      <p>本页目录</p>
      <nav>
        {sections.map(([section]) => <a href={`#${section}`}>{section}</a>)}
      </nav>
      <a class="docs-source" href="https://github.com/kinglet-lang/kinglet-lang.github.io/tree/master/src/content/docs/zh">在 GitHub 上编辑文档 ↗</a>
    </aside>

    <div class="docs-groups">
      {sections.length === 0 && <p>{t('docs.empty', locale)}</p>}
      {sections.map(([section, items], sectionIndex) => (
        <section class="docs-group" id={section}>
          <header><span>{String(sectionIndex + 1).padStart(2, '0')}</span><h2>{section}</h2></header>
          <ol>
            {items.map((item, itemIndex) => (
              <li>
                <a href={`/zh/docs/${idOf(item.id)}/`}>
                  <span>{String(itemIndex + 1).padStart(2, '0')}</span>
                  <div><h3>{item.data.title}</h3>{item.data.description && <p>{item.data.description}</p>}</div>
                  <b aria-hidden="true">→</b>
                </a>
              </li>
            ))}
          </ol>
        </section>
      ))}
    </div>
  </div>
</main>
<SiteFooter />
</BaseLayout>
